# ─────────────────────────────────────────────────────────────────────────────
# Dataflow Backend — Variables de entorno
# Copiar como .env y ajustar los valores antes de levantar el servidor.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL
DATABASE_URL=postgresql://dataflow_user:dataflow_pass@localhost:5432/dataflow

# Clave secreta para firmar las cookies de sesión (cadena aleatoria larga)
SESSION_SECRET=cambia-esta-clave-por-una-cadena-aleatoria-larga-y-secreta

# Directorio donde se guardan los archivos subidos
UPLOAD_DIR=./uploads

# Puerto del servidor Express
PORT=3000

# URL del frontend (para CORS)
FRONTEND_URL=http://localhost:5173

# ── SMTP / Email (Zimbra u otro servidor de correo) ───────────────────────────
# Si no se configuran, los emails quedan desactivados (la app funciona igual).
# SMTP_HOST=mail.circulocatolico.com.uy
# SMTP_PORT=587
# SMTP_USER=dataflow@circulocatolico.com.uy
# SMTP_PASS=clave-del-usuario-de-correo

# ── LDAP / Active Directory (opcional) ────────────────────────────────────────
# Descomentar y completar si se usa autenticación corporativa LDAP/AD.
# Si no se configuran, el sistema usa la tabla users de la base de datos.
# LDAP_URL=ldap://ad.circulocatolico.com.uy
# LDAP_BASE_DN=dc=circulocatolico,dc=com,dc=uy
# LDAP_BIND_DN=cn=dataflow-service,ou=servicios,dc=circulocatolico,dc=com,dc=uy
# LDAP_BIND_PASSWORD=clave-del-usuario-de-servicio
