# ─────────────────────────────────────────────────────────────────────────────
# Dataflow — Variables de entorno
# Copiar este archivo como .env.local y ajustar los valores.
# NUNCA subir .env.local a git (ya está en .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# URL base de la API REST.
# En desarrollo local : http://localhost:3000/api
# En producción       : https://dataflow.circulocatolico.com.uy/api
VITE_API_URL=http://localhost:3000/api

# Modo de persistencia.
# "false" → localStorage (modo actual, sin backend)
# "true"  → API REST (cuando Cómputos tenga el backend listo)
VITE_USE_API=false
